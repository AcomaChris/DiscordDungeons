{
  "name": "discord-dungeons",
  "version": "0.26.2",
  "description": "Discord Activity dungeon game",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "mkdir -p client/public && cp DEVLOG.md client/public/DEVLOG.md && node scripts/generate-version-json.js && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "server": "node server/src/ws/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "import-tilesets": "node scripts/import-tilesets.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@napi-rs/canvas": "^0.1.95",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.0",
    "marked": "^17.0.3",
    "phaser": "^3.90.0",
    "ws": "^8.19.0"
  }
}
